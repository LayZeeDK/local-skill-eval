# Modelfile for the opencode agent variant of qwen3:1.7b.
#
# qwen3:1.7b outperforms qwen3:4b for opencode tool calling:
# - 2x faster (50 tok/s vs 22 tok/s at 8 threads)
# - Half the memory (1.7 GB vs 3.2 GB loaded)
# - Better /no_think compliance (375 vs 918 tokens for 3-step workflow)
# - Fits under 2.6 GiB memory pressure threshold
#
# NO custom SYSTEM prompt -- opencode provides its own.
#
# To create: ollama create qwen3-1.7b-opencode-agent -f qwen3-1.7b-opencode-agent.Modelfile

FROM qwen3:1.7b
PARAMETER num_ctx 4096
PARAMETER num_predict 4096
PARAMETER temperature 0
PARAMETER num_batch 1024
PARAMETER num_thread 8
